{
  "expo": {
    "name": "Umade",
    "slug": "umade",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "umade",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1132b65b-3b07-4988-a65d-202a4195f732",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000,
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E9DCFA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yrhm.umade"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yrhm.umade"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-web-browser",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1132b65b-3b07-4988-a65d-202a4195f732"
      }
    },
    "owner": "umade"
  }
}
